GEMINI_API_KEY=your-gemini-api-key-here
MODEL_NAME=gemini-flash-latest

# For docker compose, DATABASE_URL and READONLY_DATABASE_URL are set directly in
# docker-compose.yml and do not need to be set here. These are only used for running
# the app outside Docker, against a local Postgres instance.
DATABASE_URL=postgresql+psycopg://reflex:reflex@localhost:5432/reflex
READONLY_DATABASE_URL=postgresql+psycopg://reflex_reader:reflex_reader@localhost:5432/reflex

MAX_ATTEMPTS=4
ROW_LIMIT=200
STATEMENT_TIMEOUT_MS=5000
LOG_LEVEL=INFO
